    "                    toolbox = configure_deap(pool.map,MIN_THICK_LAYER, MAX_THICK_LAYER,MAX_TOTAL,MAX_LAYERS,LOW_VELS, UP_VELS,main_rng,estimated_disp,nb_samples)\n",
    "\n",
