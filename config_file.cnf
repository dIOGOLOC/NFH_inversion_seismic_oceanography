# ------------------------------------------------------------------------------
#                 Configuration file of the computational routines
# ------------------------------------------------------------------------------
#
# Author: Diogo L.O.C. (locdiogo@gmail.com)
#
# Last Date: 07/2026
#
# Description:
# This is an example of configuration file, wherein global paths and parameters
# related to the analysis of quality of seismological data are defined. At least
# one file should reside in the folder in which you intend to run your scripts.
# The configuration file(s) can have any name, as long as the extension is 'cnf':
# e.g., 'analysis.cnf', 'config.cnf', 'myconfig.cnf', 'test.cnf'...
#
# The parameters are divided into several sections:
# - [paths]   : default input/output folder paths
# - [clima]   : default parameters of climatological models (GLORYS, HYCOM, WOD, CTD)
# - [sismica] : forward modeling parameters (wavelet, sampling rate, grid)
# - [gene]    : default parameters for the genetic algorithm
#
# Before using the scripts, you should at least make sure that the paths in
# section [paths] are consistent with your own files and folders organization.
#
# More information in:
# https://docs.python.org/3/library/configparser.html
#
# ------------------------------------------------------------------------------

#======
[paths]
#======

## ------------------
## Name of the folder
FOLDER_NAME = NFH

## -----------------------
## Directory of the output (Figures and Files)
FOLDER_OUTPUT = /home/diogoloc/Documents/posdoc/NFH_INVERSION/

## -----------------------------------------------------
## File with the observed near-field hydrophone trace(s)
## (generated synthetically via deepwave, or real recorded data)
OBSERVED_DATA = /home/diogoloc/Documents/posdoc/NFH_INVERSION/DATA/observed_trace.npy


#======
[clima]
#======

## -------------------------------
## Global Ocean Physics Reanalysis - https://data.marine.copernicus.eu/product/GLOBAL_MULTIYEAR_PHY_001_030/description
## This product includes daily and monthly mean files for temperature, salinity, currents, sea level, mixed layer depth
## and ice parameters from the top to the bottom.
## The global ocean output files are displayed on 50 standard levels.

## ------------------------------------------------------
## File with the initial (background/prior) sound speed profile from GLORYS,
## already interpolated onto the regular inversion grid (Z_MAX, DZ below).
MODEL_VP0 = /home/diogoloc/Documents/posdoc/NFH_INVERSION/DATA/glorys_vp0_month.npy

## -----------------------------------------------
## File with the average density model from Glorys,
## already interpolated onto the regular inversion grid (Z_MAX, DZ below).
MODEL_RHO0 = /home/diogoloc/Documents/posdoc/NFH_INVERSION/DATA/glorys_rho0_averaged_month.npy

## -----------------------------------------------------------------
## File with the Empirical Orthogonal Functions (EOFs), shape (K, N_EOFS),
## already interpolated onto the same regular grid as MODEL_VP0/MODEL_RHO0.
## Generated by EOF_glorys_analysis.ipynb.
MODEL_EOFS = /home/diogoloc/Documents/posdoc/NFH_INVERSION/DATA/glorys_eofs.npy

## ---------------------------------------------------------------------
## File with the daily/historical EOF coefficients, shape (N_EOFS, N_days),
## used only to define physically plausible search bounds for the GA
## (min/max per coefficient + MARGEM_COEF below). Also from EOF_glorys_analysis.ipynb.
MODEL_COEF_HIST = /home/diogoloc/Documents/posdoc/NFH_INVERSION/DATA/glorys_eof_coeffs.npy

## ------------------------------------------------------------
## Target month used to build the climatology/EOFs (3-letter abbreviation:
## 'Jan', 'Feb', ..., 'Dec'), matching the month the seismic data were collected.
MES_ALVO = Jul

## ------------------------------------------------
## Number of EOFs retained for the genetic inversion
N_EOFS = 6


#========
[sismica]
#========

## -----------------------------------
## Parameters for the Forward Modeling (1D normal-incidence reflectivity + convolution)

## --------------------------------------------------
## Temporal sampling rate of the synthetic seismogram (e.g., 0.002 = 2 ms)
DT = 0.002

## ----------------------------------------------
## Maximum depth for the inversion grid in meters (defines the TWT window)
Z_MAX = 1000.0

## ----------------------
## Grid spacing in meters (e.g., 20.0 m to match the 50 parameters over 1000 m)
DZ = 20.0

## ---------------------------------------------------------------
## Central frequency of the source wavelet / low-pass filter in Hz
F_PICO = 20.0

## -------------------------------------------------
## Source wavelet type used in the forward modeling.
## Currently supported: 'ricker'
WAVELET_TYPE = ricker

## ------------------------------------------------------------------
## Total wavelet window length in seconds (should be a few periods of
## 1/F_PICO; e.g. ~0.2 s for F_PICO = 20 Hz)
WAVELET_LENGTH = 0.2


#=====
[gene]
#=====

## ==========================================
## Default parameters to the inversion scheme

## ----------------------------------
## Probability of mutating each value (default=0.02 [2%])
MUTPB = 0.02

## ---------------------------------------
## The probability of performing crossover (default=0.7 [70%])
CXPB = 0.7

## ----------------------------------------------------------
## The number of individuals participating in each tournament
TOURNSIZE = 3

## ---------------------------------------
## Storing best solutions in Hall of fame:
HOF_NUM = 100

## ---------------------
## Number of generations:
NGEN = 50

## ---------------
## Number of individuals in population:
POPULATION = 1000

## --------------------
## Number of inversions:
N_INV = 2

## ---------------
## MULTIPROCESSING
NUM_PROCESS = 10

## --------------------------------------------------------------------
## Extra fractional margin applied beyond the historical min/max of each
## EOF coefficient (from MODEL_COEF_HIST) when defining GA search bounds.
## e.g. 0.2 = 20% extra room on each side.
MARGEM_COEF = 0.2

## ------------------------------------------------------------------
## Distribution index (eta) for the bounded genetic operators
## (cxSimulatedBinaryBounded / mutPolynomialBounded). Higher = children
## stay closer to the parents (more exploitation); lower = more exploration.
ETA_GENE = 20.0
